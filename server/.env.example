# Server
PORT=5000
NODE_ENV=production

# MongoDB
MONGODB_URI=mongodb://localhost:27017/chdi

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_64_chars_here_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_64_chars_here_change_in_production
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin Registration Secret (required to create admin accounts)
ADMIN_SECRET=your_admin_registration_secret_change_this

# URL do cliente em produção
CLIENT_URL=https://anyprem.store
